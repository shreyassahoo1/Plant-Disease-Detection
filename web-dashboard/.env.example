# AgroNet AI — Web Dashboard Environment Variables
# Rename this file to .env and fill in your values

# ── Gemini AI (required for Smart Scan) ──────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── ESP32 Hardware URLs (optional — set to match your local network) ──────────
VITE_ROVER_URL=http://172.23.128.15
VITE_ESP32_SENSOR_URL=http://172.23.128.42/sensors
VITE_ESP32_CAM_URL=http://172.23.128.247:81/stream
VITE_ESP32_CAM_CAPTURE_URL=http://172.23.128.247/capture
